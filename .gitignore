## Unity generated .gitignore
# Project files to ignore for Unity projects

# OS generated files
.DS_Store
Thumbs.db

# Visual Studio / Rider
.vs/
.vscode/
.vsconfig
*.csproj
*.slnx
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# Unity generated folders
Library/
Temp/
Obj/
Build/
Builds/
Logs/
MemoryCaptures/

# Autogenerated JetBrains Rider files
.idea/
*.sln.iml

# Asset store tools (if present)
Assets/AssetStoreTools*

# Gradle / Android
*.apk
*.aab

# Plugins / caches
*.unitypackage

# NPM / Yarn
node_modules/

# Ignore local settings
Assets/Plugins/Editor/JetBrains*

# Uncomment if you have local secrets
# UserSettings/
